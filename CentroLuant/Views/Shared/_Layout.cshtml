<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Centro Odontológico Luant</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                display: flex;
                min-height: 100vh;
                background: #f0f4f8;
                font-family: 'Segoe UI', sans-serif;
            }

            /* SIDEBAR */
            .sidebar {
                width: 260px;
                min-height: 100vh;
                background: linear-gradient(180deg, #0a2d6e 0%, #1565c0 60%, #0097a7 100%);
                display: flex;
                flex-direction: column;
                position: fixed;
                left: 0;
                top: 0;
                z-index: 1000;
                box-shadow: 4px 0 20px rgba(0,0,0,0.15);
                transition: transform 0.3s ease;
            }

            .sidebar-header {
                padding: 22px 18px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                display: flex;
                align-items: center;
                gap: 12px;
            }

            .sidebar-logo-icon {
                width: 42px;
                height: 42px;
                background: rgba(255,255,255,0.15);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                border: 1px solid rgba(255,255,255,0.2);
            }

                .sidebar-logo-icon i {
                    color: white;
                    font-size: 1.3rem;
                }

            .sidebar-logo-text h4 {
                color: white;
                font-size: 0.85rem;
                font-weight: 700;
                margin: 0;
                line-height: 1.3;
            }

            .sidebar-logo-text small {
                color: rgba(255,255,255,0.55);
                font-size: 0.7rem;
            }

            .sidebar-user {
                padding: 14px 18px;
                border-bottom: 1px solid rgba(255,255,255,0.1);
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .user-avatar {
                width: 36px;
                height: 36px;
                background: rgba(255,255,255,0.2);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

                .user-avatar i {
                    color: white;
                    font-size: 1rem;
                }

            .user-info .uname {
                color: white;
                font-size: 0.82rem;
                font-weight: 600;
                display: block;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
                max-width: 160px;
            }

            .user-info .urole {
                color: rgba(255,255,255,0.55);
                font-size: 0.7rem;
            }

            .sidebar-nav {
                flex: 1;
                padding: 12px 0;
                overflow-y: auto;
            }

            .nav-section-label {
                padding: 10px 18px 4px;
                color: rgba(255,255,255,0.35);
                font-size: 0.65rem;
                font-weight: 700;
                letter-spacing: 1.2px;
                text-transform: uppercase;
            }

            .nav-item-link {
                display: flex;
                align-items: center;
                gap: 11px;
                padding: 10px 18px;
                color: rgba(255,255,255,0.75);
                text-decoration: none;
                font-size: 0.875rem;
                transition: all 0.2s;
                border-left: 3px solid transparent;
                cursor: pointer;
            }

                .nav-item-link:hover, .nav-item-link.active {
                    background: rgba(255,255,255,0.12);
                    color: white;
                    border-left-color: #80deea;
                }

                .nav-item-link i {
                    font-size: 1rem;
                    width: 18px;
                    text-align: center;
                    flex-shrink: 0;
                }

            .nav-submenu {
                display: none;
                background: rgba(0,0,0,0.12);
            }

                .nav-submenu .nav-item-link {
                    padding-left: 46px;
                    font-size: 0.82rem;
                }

                .nav-submenu.open {
                    display: block;
                }

            .sidebar-footer {
                padding: 14px 18px;
                border-top: 1px solid rgba(255,255,255,0.1);
            }

            .logout-link {
                display: flex;
                align-items: center;
                gap: 10px;
                color: rgba(255,255,255,0.65);
                text-decoration: none;
                font-size: 0.875rem;
                padding: 9px 10px;
                border-radius: 8px;
                transition: all 0.2s;
            }

                .logout-link:hover {
                    background: rgba(255,255,255,0.1);
                    color: white;
                }

            /* MAIN CONTENT */
            .main-content {
                margin-left: 260px;
                flex: 1;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                min-width: 0;
            }

            .topbar {
                background: white;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                gap: 12px;
                box-shadow: 0 2px 8px rgba(0,0,0,0.06);
                border-bottom: 1px solid #e8f0fe;
                position: sticky;
                top: 0;
                z-index: 100;
            }

            .topbar-toggle {
                display: none;
                background: none;
                border: none;
                font-size: 1.3rem;
                color: #1565c0;
                cursor: pointer;
                padding: 4px;
            }

            .topbar-title {
                font-size: 1rem;
                font-weight: 700;
                color: #0a2d6e;
                flex: 1;
            }

            .topbar-date {
                color: #999;
                font-size: 0.8rem;
                white-space: nowrap;
            }

            .content-area {
                flex: 1;
                padding: 0;
            }

            .alert-wrapper {
                padding: 12px 20px 0;
            }

            /* OVERLAY */
            .sidebar-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.5);
                z-index: 999;
            }

                .sidebar-overlay.show {
                    display: block;
                }

            /* RESPONSIVE */
            @@media (max-width: 900px) {
                .sidebar {
                    transform: translateX(-100%);
                }

                    .sidebar.open {
                        transform: translateX(0);
                    }

                .main-content {
                    margin-left: 0;
                }

                .topbar-toggle {
                    display: block;
                }

                .topbar-date {
                    display: none;
                }
            }

            @@media (max-width: 480px) {
                .topbar {
                    padding: 10px 14px;
                }

                .content-area {
                    padding: 0;
                }
            }
    </style>
</head>
<body>

    <div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-logo-icon">
                <i class="bi bi-hospital"></i>
            </div>
            <div class="sidebar-logo-text">
                <h4>Centro Odontológico<br>Luant</h4>
                <small>Sistema de Gestión</small>
            </div>
        </div>

        <div class="sidebar-user">
            <div class="user-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <div class="user-info">
                <span class="uname">@Context.Session.GetString("Usuario")</span>
                <span class="urole">@Context.Session.GetString("Rol")</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Principal</div>
            <a href="/Home/Index" class="nav-item-link">
                <i class="bi bi-house-fill"></i> Inicio
            </a>

            <div class="nav-section-label">Módulos</div>
            <a href="/Paciente/Index" class="nav-item-link">
                <i class="bi bi-people-fill"></i> Pacientes
            </a>

            <div class="nav-item-link" onclick="toggleSubmenu('citasMenu')">
                <i class="bi bi-calendar2-check-fill"></i>
                <span style="flex:1">Citas</span>
                <i class="bi bi-chevron-down" style="font-size:0.75rem;" id="citasIcon"></i>
            </div>
            <div class="nav-submenu" id="citasMenu">
                <a href="/Cita/Index" class="nav-item-link">
                    <i class="bi bi-list-ul"></i> Ver todas
                </a>
                <a href="/Cita/Consultar" class="nav-item-link">
                    <i class="bi bi-search"></i> Por paciente
                </a>
                <a href="/Cita/Registrar" class="nav-item-link">
                    <i class="bi bi-plus-circle"></i> Registrar
                </a>
            </div>

            <a href="/Historial/Index" class="nav-item-link">
                <i class="bi bi-clipboard2-heart-fill"></i> Gestión Clínica
            </a>

            <a href="/Factura/Index" class="nav-item-link">
                <i class="bi bi-receipt-cutoff"></i> Facturación
            </a>

            <div class="nav-section-label">Administración</div>
            <a href="/Usuario/Index" class="nav-item-link">
                <i class="bi bi-person-gear"></i> Usuarios
            </a>
        </nav>

        <div class="sidebar-footer">
            <a href="/Account/Logout" class="logout-link">
                <i class="bi bi-box-arrow-left"></i> Cerrar Sesión
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="topbar">
            <button class="topbar-toggle" onclick="openSidebar()">
                <i class="bi bi-list"></i>
            </button>
            <span class="topbar-title">@ViewData["Title"]</span>
            <span class="topbar-date">
                <i class="bi bi-calendar3 me-1"></i>
                @DateTime.Now.ToString("dd/MM/yyyy")
            </span>
        </div>

        @if (TempData["Exito"] != null)
        {
            <div class="alert-wrapper">
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-check-circle-fill"></i>
                    @TempData["Exito"]
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-wrapper">
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        <div class="content-area">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function openSidebar() {
        document.getElementById('sidebar').classList.add('open');
        document.getElementById('sidebarOverlay').classList.add('show');
        }

        function closeSidebar() {
        document.getElementById('sidebar').classList.remove('open');
        document.getElementById('sidebarOverlay').classList.remove('show');
        }

        function toggleSubmenu(id) {
        const menu = document.getElementById(id);
        menu.classList.toggle('open');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>