@model CentroLuant.Models.Usuario
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Editar Usuario</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Editar" method="post">
                        <input type="hidden" asp-for="ID_Usuario" />
                        <div class="mb-3">
                            <label class="form-label">Nombre Completo *</label>
                            <input asp-for="NombreCompleto" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Usuario</label>
                            <input asp-for="UsuarioLogin" class="form-control" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nueva Contraseña</label>
                            <input asp-for="ContrasenaHash" type="password" class="form-control"
                                   placeholder="Dejar vacío para mantener la actual" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rol *</label>
                            <select asp-for="Rol" class="form-select" required>
                                <option value="Recepcionista">Recepcionista</option>
                                <option value="Especialista">Especialista</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Actualizar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>