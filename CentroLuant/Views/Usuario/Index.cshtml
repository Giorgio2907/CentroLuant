@model IEnumerable<CentroLuant.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Gestión de usuarios</h3>
    <a asp-action="Crear" class="btn btn-primary">+ Nuevo usuario</a>
</div>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Nombre completo</th>
                <th>Usuario</th>
                <th>Rol</th>
                <th>Estado</th>
                <th class="text-end">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var usuario in Model)
            {
                <tr>
                    <td>@usuario.NombreCompleto</td>
                    <td>@usuario.UsuarioLogin</td>
                    <td>@usuario.Rol</td>
                    <td>
                        @if (usuario.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Editar" asp-route-id="@usuario.ID_Usuario" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                        <form asp-action="CambiarEstado" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@usuario.ID_Usuario" />
                            <input type="hidden" name="activo" value="@usuario.Activo" />
                            @if (usuario.Activo)
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger">Desactivar</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-success">Activar</button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
