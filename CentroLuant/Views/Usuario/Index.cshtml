@model IEnumerable<CentroLuant.Models.Usuario>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Gestión de Usuarios</h2>
        <a asp-action="Crear" class="btn btn-primary">+ Crear Usuario</a>
    </div>
    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>Nombre</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        <tr>
                            <td>@u.NombreCompleto</td>
                            <td>@u.UsuarioLogin</td>
                            <td>@u.Rol</td>
                            <td>
                                <span class="badge @(u.Activo ? "bg-success" : "bg-danger")">
                                    @(u.Activo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td>
                                <a asp-action="Editar" asp-route-id="@u.ID_Usuario"
                                   class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="CambiarEstado" asp-route-id="@u.ID_Usuario"
                                   class="btn btn-sm @(u.Activo ? "btn-danger" : "btn-success")"
                                   onclick="return confirm('¿Cambiar estado del usuario?')">
                                    @(u.Activo ? "Desactivar" : "Activar")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>