@model CentroLuant.Models.Usuario
@{
    ViewData["Title"] = "Crear Usuario";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Crear Nuevo Usuario</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }
                    <form asp-action="Crear" method="post">
                        <div class="mb-3">
                            <label class="form-label">Nombre Completo *</label>
                            <input asp-for="NombreCompleto" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Usuario *</label>
                            <input asp-for="UsuarioLogin" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Contraseña *</label>
                            <input asp-for="ContrasenaHash" type="password" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rol *</label>
                            <select asp-for="Rol" class="form-select" required>
                                <option value="">-- Seleccione --</option>
                                <option value="Recepcionista">Recepcionista</option>
                                <option value="Especialista">Especialista</option>
                                <option value="Admin">Admin</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Guardar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>