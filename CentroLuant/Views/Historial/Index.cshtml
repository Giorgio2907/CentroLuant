@model CentroLuant.Models.HistorialMedico
@{
    ViewData["Title"] = "Gestión Clínica";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">Gestión Clínica</h2>
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="d-flex gap-2">
                <input type="text" name="dni" class="form-control" placeholder="Ingrese DNI del paciente" />
                <button type="submit" class="btn btn-primary">Buscar</button>
            </form>
        </div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (Model != null)
    {
        <div class="card mb-3">
            <div class="card-header bg-primary text-white d-flex justify-content-between">
                <span>Paciente: @Model.NombrePaciente</span>
                <span>Historial N° @Model.ID_Historial</span>
            </div>
            <div class="card-body">
                <p><strong>Fecha de Creación:</strong> @Model.FechaCreacion</p>
                <p><strong>Observaciones Iniciales:</strong> @Model.ObservacionesIniciales</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                        <span>Tratamientos Registrados</span>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.Tratamientos != null && (ViewBag.Tratamientos as IEnumerable<CentroLuant.Models.Tratamiento>).Any())
                        {
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Tipo</th>
                                        <th>Diagnóstico</th>
                                        <th>Costo</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in ViewBag.Tratamientos as IEnumerable<CentroLuant.Models.Tratamiento>)
                                    {
                                        <tr>
                                            <td>@t.FechaTratamiento</td>
                                            <td>@t.TipoTratamiento</td>
                                            <td>@t.Diagnostico</td>
                                            <td>S/ @t.Costo</td>
                                            <td>
                                                <a asp-action="EditarTratamiento" asp-route-id="@t.ID_Tratamiento"
                                                   class="btn btn-sm btn-warning">Editar</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted">No hay tratamientos registrados.</p>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-header bg-success text-white">
                        Registrar Nuevo Tratamiento
                    </div>
                    <div class="card-body">
                        <form asp-action="AgregarTratamiento" method="post">
                            <input type="hidden" name="ID_Historial" value="@Model.ID_Historial" />
                            <input type="hidden" name="DNI_Paciente" value="@Model.DNI_Paciente" />
                            <div class="mb-2">
                                <label class="form-label">Fecha</label>
                                <input type="date" name="FechaTratamiento" class="form-control" required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Tipo de Tratamiento</label>
                                <input type="text" name="TipoTratamiento" class="form-control"
                                       placeholder="Ej: Endodoncia, Profilaxis" required />
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Diagnóstico</label>
                                <textarea name="Diagnostico" class="form-control" rows="2"
                                          placeholder="Diagnóstico resumido"></textarea>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Observaciones</label>
                                <textarea name="Observaciones" class="form-control" rows="2"
                                          placeholder="Notas clínicas relevantes"></textarea>
                            </div>
                            <div class="mb-2">
                                <label class="form-label">Costo (S/)</label>
                                <input type="number" name="Costo" class="form-control"
                                       step="0.01" placeholder="0.00" required />
                            </div>
                            <button type="submit" class="btn btn-success w-100">Guardar Tratamiento</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (ViewBag.Paciente != null)
    {
        <div class="alert alert-warning">
            El paciente no tiene historial clínico.
            <a asp-action="Crear" asp-route-dni="@ViewBag.Paciente.DNI" class="btn btn-sm btn-primary ms-2">Crear Historial</a>
        </div>
    }
</div>