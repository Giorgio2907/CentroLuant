@model CentroLuant.Models.Paciente
@{
    ViewData["Title"] = "Editar Paciente";
}

<style>
    .page-wrapper {
        padding: 20px 25px;
    }

    .form-container {
        max-width: 600px;
        margin: 0 auto;
    }

    .form-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .form-card-header {
        background: linear-gradient(135deg, #f57f17 0%, #ef6c00 100%);
        padding: 22px 26px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .form-card-header h4 {
            color: white;
            font-weight: 800;
            font-size: 1.15rem;
            margin: 0;
        }

        .form-card-header i {
            color: white;
            font-size: 1.3rem;
        }

    .form-card-body {
        padding: 28px 26px;
    }

    .form-row-double {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-group-custom {
        margin-bottom: 18px;
    }

    .form-label-custom {
        display: block;
        font-size: 0.82rem;
        font-weight: 700;
        color: #555;
        margin-bottom: 7px;
    }

    .form-control-custom {
        width: 100%;
        border: 2px solid #e8f0fe;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 0.9rem;
        background: #f8faff;
        outline: none;
        transition: all 0.2s;
    }

        .form-control-custom:focus {
            border-color: #f57f17;
            background: white;
        }

        .form-control-custom[readonly] {
            background: #eef2f8;
            color: #888;
            cursor: not-allowed;
        }

    select.form-control-custom {
        cursor: pointer;
    }

    .alert-custom-danger {
        background: #ffebee;
        color: #c62828;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 18px;
        font-size: 0.85rem;
    }

        .alert-custom-danger p {
            margin: 0;
        }

            .alert-custom-danger p + p {
                margin-top: 4px;
            }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 22px;
    }

    .btn-warning-solid {
        background: linear-gradient(135deg, #f57f17, #ef6c00);
        border: none;
        border-radius: 10px;
        color: white;
        padding: 10px 22px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-warning-solid:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(245,127,23,0.35);
            color: white;
        }

    .btn-secondary-custom {
        background: #f0f4f8;
        border: none;
        border-radius: 10px;
        color: #555;
        padding: 10px 22px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-secondary-custom:hover {
            background: #e2e8f0;
            color: #333;
        }

    @@media (max-width: 600px) {
        .page-wrapper {
            padding: 15px;
        }

        .form-row-double {
            grid-template-columns: 1fr;
        }

        .form-actions {
            flex-direction: column;
        }

        .btn-warning-solid,
        .btn-secondary-custom {
            justify-content: center;
            width: 100%;
        }
    }
</style>

<div class="page-wrapper">
    <div class="form-container">
        <div class="form-card">
            <div class="form-card-header">
                <i class="bi bi-person-lines-fill"></i>
                <h4>Editar Paciente</h4>
            </div>
            <div class="form-card-body">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-custom-danger">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <p>@error.ErrorMessage</p>
                        }
                    </div>
                }

                <form asp-action="Editar" method="post">
                    <input type="hidden" asp-for="DNI" />

                    <div class="form-group-custom">
                        <label class="form-label-custom">DNI</label>
                        <input asp-for="DNI" class="form-control-custom" readonly />
                    </div>

                    <div class="form-row-double">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Nombres *</label>
                            <input asp-for="Nombres" class="form-control-custom" required />
                        </div>
                        <div class="form-group-custom">
                            <label class="form-label-custom">Apellidos *</label>
                            <input asp-for="Apellidos" class="form-control-custom" required />
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <label class="form-label-custom">Fecha de Nacimiento</label>
                        <input asp-for="FechaNacimiento" type="date" class="form-control-custom"
                               min="1900-01-01" max="@DateTime.Today.AddDays(-1).ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="form-row-double">
                        <div class="form-group-custom">
                            <label class="form-label-custom">Teléfono</label>
                            <input asp-for="Telefono" class="form-control-custom" maxlength="9" pattern="\d{9}"
                                   title="Debe tener 9 dígitos" inputmode="numeric" />
                        </div>
                        <div class="form-group-custom">
                            <label class="form-label-custom">Correo Electrónico</label>
                            <input asp-for="CorreoElectronico" type="email" class="form-control-custom"
                                   placeholder="ejemplo@gmail.com" />
                        </div>
                    </div>

                    <div class="form-group-custom">
                        <label class="form-label-custom">Dirección</label>
                        <input asp-for="Direccion" class="form-control-custom" />
                    </div>

                    <div class="form-group-custom">
                        <label class="form-label-custom">Género</label>
                        <select asp-for="Genero" class="form-control-custom">
                            <option value="">-- Seleccione --</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-warning-solid">
                            <i class="bi bi-check-lg"></i> Actualizar
                        </button>
                        <a asp-action="Index" class="btn-secondary-custom">
                            <i class="bi bi-x-lg"></i> Cancelar
                        </a>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>