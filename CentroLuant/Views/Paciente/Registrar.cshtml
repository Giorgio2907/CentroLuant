@model CentroLuant.Models.Paciente
@{
    ViewData["Title"] = "Registrar Paciente";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nuevo Paciente</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }
                    <form asp-action="Registrar" method="post">
                        <div class="mb-3">
                            <label class="form-label">DNI *</label>
                            <div class="input-group">
                                <input asp-for="DNI" class="form-control" maxlength="8"
                                       id="dniInput" placeholder="Ingrese 8 dígitos" required />
                                <button type="button" class="btn btn-outline-primary" onclick="consultarDni()">
                                    <i class="bi bi-search"></i> Consultar
                                </button>
                            </div>
                            <div id="dniMensaje" class="mt-1"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nombres *</label>
                            <input asp-for="Nombres" class="form-control" id="nombres" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Apellidos *</label>
                            <input asp-for="Apellidos" class="form-control" id="apellidos" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fecha de Nacimiento</label>
                            <input asp-for="FechaNacimiento" type="date" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono</label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            <input asp-for="CorreoElectronico" type="email" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Dirección</label>
                            <input asp-for="Direccion" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Género</label>
                            <select asp-for="Genero" class="form-select">
                                <option value="">-- Seleccione --</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Femenino">Femenino</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Guardar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function consultarDni() {
            const dni = document.getElementById('dniInput').value;
            const mensaje = document.getElementById('dniMensaje');

            if (dni.length !== 8) {
                mensaje.innerHTML = '<span class="text-danger">El DNI debe tener 8 dígitos</span>';
                return;
            }

            mensaje.innerHTML = '<span class="text-muted">Consultando...</span>';

            try {
                const response = await fetch(`/Paciente/ConsultarDni?dni=${dni}`);
                const data = await response.json();

                if (data.success) {
                    document.getElementById('nombres').value = data.nombres;
                    document.getElementById('apellidos').value = data.apellidos;
                    mensaje.innerHTML = '<span class="text-success"><i class="bi bi-check-circle"></i> Datos encontrados</span>';
                } else {
                    mensaje.innerHTML = `<span class="text-danger">${data.message}</span>`;
                }
            } catch {
                mensaje.innerHTML = '<span class="text-danger">Error al consultar el servicio</span>';
            }
        }
    </script>
}