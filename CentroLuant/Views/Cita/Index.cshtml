@model IEnumerable<CentroLuant.Models.Cita>
@{
    ViewData["Title"] = "Gestión de Citas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">Gestión de Citas</h2>
        <a asp-action="Registrar" class="btn btn-primary">+ Registrar Cita</a>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <form asp-action="Consultar" method="get" class="d-flex gap-2">
                <input type="text" name="dni" class="form-control" placeholder="Buscar por DNI del paciente" />
                <button type="submit" class="btn btn-outline-primary">Buscar</button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>#</th>
                        <th>Paciente</th>
                        <th>Especialista</th>
                        <th>Fecha</th>
                        <th>Hora</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cita in Model)
                    {
                        <tr>
                            <td>@cita.ID_Cita</td>
                            <td>@cita.NombrePaciente</td>
                            <td>@cita.NombreEspecialista</td>
                            <td>@cita.Fecha</td>
                            <td>@cita.Hora</td>
                            <td>
                                <span class="badge @(cita.Estado == "Programada" ? "bg-success" : cita.Estado == "Cancelada" ? "bg-danger" : "bg-warning")">
                                    @cita.Estado
                                </span>
                            </td>
                            <td>
                                <a asp-action="Reprogramar" asp-route-id="@cita.ID_Cita" class="btn btn-sm btn-warning">Reprogramar</a>
                                <a asp-action="Cancelar" asp-route-id="@cita.ID_Cita" class="btn btn-sm btn-danger"
                                   onclick="return confirm('¿Cancelar esta cita?')">Cancelar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>