@model CentroLuant.Models.Cita
@{
    ViewData["Title"] = "Reprogramar Cita";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-warning">
                    <h4 class="mb-0">Reprogramar Cita #@Model.ID_Cita</h4>
                </div>
                <div class="card-body">
                    <p><strong>Paciente:</strong> @Model.NombrePaciente</p>
                    <p><strong>Especialista:</strong> @Model.NombreEspecialista</p>
                    <form asp-action="Reprogramar" method="post">
                        <input type="hidden" name="id" value="@Model.ID_Cita" />
                        <div class="mb-3">
                            <label class="form-label">Nueva Fecha</label>
                            <input type="date" name="nuevaFecha" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nueva Hora</label>
                            <input type="time" name="nuevaHora" class="form-control" required />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-warning">Reprogramar</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>