@model CentroLuant.Models.Cita
@{
    ViewData["Title"] = "Registrar Cita";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Registrar Nueva Cita</h4>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <p class="mb-0">@error.ErrorMessage</p>
                            }
                        </div>
                    }
                    <form asp-action="Registrar" method="post">
                        <div class="mb-3">
                            <label class="form-label">DNI del Paciente</label>
                            <input asp-for="DNI_Paciente" class="form-control" placeholder="Ej: 12345678" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Especialista</label>
                            <select asp-for="ID_Especialista" class="form-select" required>
                                <option value="">-- Seleccione especialista --</option>
                                @foreach (var e in ViewBag.Especialistas as IEnumerable<CentroLuant.Models.Especialista>)
                                {
                                    <option value="@e.ID_Especialista">@e.NombreCompleto - @e.Especialidad</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Fecha</label>
                            <input asp-for="Fecha" type="date" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Hora</label>
                            <input asp-for="Hora" type="time" class="form-control" required />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Guardar Cita</button>
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>