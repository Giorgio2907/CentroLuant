@model IEnumerable<CentroLuant.Models.Factura>
@{
    ViewData["Title"] = "Facturación";
}

<style>
    .page-wrapper {
        padding: 20px 25px;
    }

    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }

        .page-header h2 {
            font-size: 1.3rem;
            font-weight: 800;
            color: #0a2d6e;
            margin: 0;
        }

    .card-custom {
        background: white;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
    }

    .alert-custom {
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 0.88rem;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }

    .alert-error-custom {
        background: #ffebee;
        color: #c62828;
        border: 1px solid #ffcdd2;
    }

    .alert-success-custom {
        background: #e8f5e9;
        color: #2e7d32;
        border: 1px solid #c8e6c9;
    }

    .generar-bar {
        padding: 18px 20px;
        border-bottom: 1px solid #f0f4f8;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

        .generar-bar form {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            width: 100%;
        }

    .input-custom {
        border: 2px solid #e8f0fe;
        border-radius: 10px;
        padding: 9px 15px;
        font-size: 0.88rem;
        flex: 1;
        min-width: 220px;
        outline: none;
        transition: all 0.2s;
    }

        .input-custom:focus {
            border-color: #e65100;
            background-color: #fff;
        }

    .btn-primary-custom {
        background: linear-gradient(135deg, #e65100, #ef6c00);
        border: none;
        border-radius: 10px;
        color: white;
        padding: 9px 18px;
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(230,81,0,0.3);
            color: white;
        }

    .table-custom {
        width: 100%;
        border-collapse: collapse;
    }

        .table-custom th {
            background: #f8faff;
            color: #555;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            padding: 12px 16px;
            border-bottom: 2px solid #e8f0fe;
            white-space: nowrap;
        }

        .table-custom td {
            padding: 12px 16px;
            font-size: 0.875rem;
            color: #333;
            border-bottom: 1px solid #f5f7ff;
            vertical-align: middle;
        }

        .table-custom tr:hover td {
            background: #f8faff;
        }

    .estado-badge {
        border-radius: 20px;
        padding: 5px 14px;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .estado-pagado {
        background: #e8f5e9;
        color: #2e7d32;
    }

    .estado-pendiente {
        background: #fff8e1;
        color: #f57f17;
    }

    .btn-action {
        border: none;
        border-radius: 7px;
        padding: 5px 10px;
        font-size: 0.78rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn-info-custom {
        background: #e3f2fd;
        color: #1565c0;
    }

        .btn-info-custom:hover {
            background: #1565c0;
            color: white;
        }

    .btn-success-custom {
        background: #e8f5e9;
        color: #2e7d32;
    }

        .btn-success-custom:hover {
            background: #2e7d32;
            color: white;
        }

    .btn-danger-custom {
        background: #ffebee;
        color: #c62828;
    }

        .btn-danger-custom:hover {
            background: #c62828;
            color: white;
        }

    .empty-state {
        text-align: center;
        padding: 50px 20px;
        color: #aaa;
    }

        .empty-state i {
            font-size: 3rem;
            display: block;
            margin-bottom: 10px;
        }

    @@media (max-width: 768px) {
        .page-wrapper {
            padding: 15px;
        }

        .table-custom th:nth-child(3),
        .table-custom td:nth-child(3) {
            display: none;
        }
    }
</style>

<div class="page-wrapper">
    <div class="page-header">
        <h2><i class="bi bi-receipt-cutoff me-2" style="color:#e65100;"></i>Facturación</h2>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert-custom alert-success-custom">
            <i class="bi bi-check-circle-fill"></i>
            <span>@TempData["Exito"]</span>
        </div>
    }

    <div class="card-custom mb-3">
        <div class="generar-bar">
            <form method="get" asp-action="Generar">
                <input type="text" name="dni" class="input-custom" placeholder="DNI del paciente para generar factura" />
                <button type="submit" class="btn-primary-custom">
                    <i class="bi bi-plus-lg"></i> Generar Factura
                </button>
            </form>
        </div>
    </div>

    <div class="card-custom">
        <div style="overflow-x:auto;">
            <table class="table-custom">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Paciente</th>
                        <th>Fecha</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var f in Model)
                        {
                            <tr>
                                <td><span style="font-family:monospace;font-weight:600;">@f.ID_Factura</span></td>
                                <td style="font-weight:600;">@f.NombrePaciente</td>
                                <td>@f.FechaEmision</td>
                                <td style="font-weight:700;color:#e65100;">S/ @f.MontoTotal</td>
                                <td>
                                    <span class="estado-badge @(f.EstadoPago == "Pagado" ? "estado-pagado" : "estado-pendiente")">
                                        @f.EstadoPago
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:5px;flex-wrap:wrap;">
                                        <a asp-action="Detalle" asp-route-id="@f.ID_Factura" class="btn-action btn-info-custom">
                                            <i class="bi bi-eye"></i> Ver
                                        </a>
                                        @if (f.EstadoPago == "Pendiente")
                                        {
                                            <a asp-action="ActualizarEstado" asp-route-id="@f.ID_Factura" asp-route-estado="Pagado"
                                               class="btn-action btn-success-custom">
                                                <i class="bi bi-check-circle"></i> Marcar Pagado
                                            </a>
                                        }
                                        <a asp-action="Eliminar" asp-route-id="@f.ID_Factura"
                                           class="btn-action btn-danger-custom"
                                           onclick="return confirm('¿Eliminar esta factura permanentemente?')">
                                            <i class="bi bi-trash"></i> Eliminar
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <i class="bi bi-receipt"></i>
                                    No hay facturas registradas aún.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
